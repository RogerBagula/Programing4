         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Abs", "[", 
             RowBox[{"d", "+", "1"}], "]"}], "<", "0.01"}], ",", 
           RowBox[{"-", "M"}], ",", 
           RowBox[{"M", "/", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"Sign", "[", "d", "]"}], " ", 
              RowBox[{
               RowBox[{"Abs", "[", "d", "]"}], "^", 
               RowBox[{"(", 
                RowBox[{"1", "/", "3"}], ")"}]}]}], ")"}]}]}], "]"}]}], 
        "]"}]}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
