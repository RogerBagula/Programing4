Notebook[{

Cell[CellGroupData[{
Cell["\<\
(* ============================================================
   Fast Kleinian Limit Set  +  Farey Pleating Rays
   Strip view  AND  Poincare disk view
   Based on: Leys/Steemann fast escape algorithm
   Generators (Maskit parametrisation):
     a[z] = (t*z - I) / (-I*z)
     A[z] = I / (I*z + t)
     b[z] = z + 2
     B[z] = z - 2
   Pleating rays: Farey p/q rational lines
   Mathematica 13.2
   ============================================================ *)

(* --- 0. User parameters ----------------------------------------- *)
tval      = 1.92 + 0.03*I;   (* Maskit parameter - butterfly value  *)
kSep      = 0.2;              (* separation line k parameter         *)
mSep      = 5.;               (* separation line m parameter         *)
maxN      = 30;               (* max iterations in escape            *)
res       = 2000;              (* pixel resolution                    *)
fareyDepth = 10;               (* Farey depth: 4=fast, 6=fine         *)

(* ============================================================ *)

(* --- 1. Separation line ----------------------------------------- *)
separation[x_, t_, k_, m_] :=
  Module[{u = Re[t], v = Im[t]},
    u/2 - Sign[x + v/2] * k * u * (1 - Exp[-m * Abs[x + v/2]])]

(* --- 2. Fast Kleinian compiled escape --------------------------- *)
(* Returns: 0=outside, 1=generator a/A region (blue),
            2=generator b/B region (red), 3=max iter (green),
            negative = stable 2-cycle depth                        *)
kleinC = Compile[{{z, _Complex},
                  {tRe, _Real}, {tIm, _Real},
                  {kk, _Real},  {mm, _Real},
                  {maxIter, _Integer}},
  Module[{t, u, v, xi, yi, zi = 1. + I,
          k = 1, low = 1. + I, high = 1. + I},
    t  = tRe + tIm*I;
    u  = tRe;
    v  = tIm;
    xi = Re[z];
    yi = Im[z];
    If[yi < 0. || yi > u, Return[0]];
    Do[
      xi = Mod[xi + 1. + v*yi/u, 2.] - 1. - v*yi/u;
      zi = xi + I*yi;
      If[yi < u/2. + Sign[xi + v/2.]*kk*u*(1. - Exp[-mm*Abs[xi + v/2.]]),
        (* lower region: generator a/A *)
        If[Abs[zi - low]  < 1.*^-4, k = -n; Break[], low  = zi];
        k  = 1;
        zi = I*t + 1./zi,
        (* upper region: generator b/B *)
        If[Abs[zi - high] < 1.*^-4, k = -n; Break[], high = zi];
        zi = I/(I*zi + t);
        k  = 2];
      xi = Re[zi]; yi = Im[zi];
      If[yi < 0. || yi > u, Break[]];
      k = 3,
      {n, 1, maxIter}];
    k],
  CompilationTarget -> \"C\",
  RuntimeOptions -> \"Speed\"]

(* --- 3. Render strip image -------------------------------------- *)
Print[\"Rendering Kleinian strip ...\"];
u = Re[tval]; v = Im[tval];
xres = res; yres = res;
dx = 2./(xres - 1);
dy = u/(yres - 1);   (* strip height = Re[t] *)

AbsoluteTiming[
  imgStrip = Table[
    kleinC[x + I*y,
           Re[tval], Im[tval],
           kSep, mSep, maxN],
    {y, 0., u, dy}, {x, -1., 1., dx}];
]

dodger = ColorData[\"Legacy\", \"DodgerBlue\"];
navy   = ColorData[\"Legacy\", \"Navy\"];

stripPlot = MatrixPlot[imgStrip,
  DataReversed -> {False, True},
  ImageSize -> 800,
  ColorFunctionScaling -> False,
  ColorFunction -> (Which[
    # <= 0,  White,
    # == 1,  dodger,
    # == 2,  Red,
    True,    Green] &),
  PlotLabel -> Style[
    \"Kleinian Limit Set (strip)   t = \" <> ToString[N[tval,4]],
    13, Bold],
  Frame -> True];

stripPlot

(* --- 4. Farey sequence ------------------------------------------ *)
fareySeq[n_] := Sort[DeleteDuplicates[
  Flatten[Table[p/q, {q, 1, n}, {p, 0, q}]]]];

allFarey = fareySeq[fareyDepth];
Print[\"Farey fractions (depth \", fareyDepth, \"): \", Length[allFarey]]

(* --- 5. Pleating rays via word trace ---------------------------- *)
(* Generators as Mobius matrices:
   a  = {{0, -I}, {-I, tval}}   i.e. (t*z-I)/(-I*z)
   A  = {{I, 0},  {I, tval}}    i.e. I/(I*z+t)
   Here we use s1/s2 Maskit form for word trace, matching v2/v3    *)

wordTrace[p_Integer, q_Integer, tc_Complex, t2c_Complex] :=
  Module[{s1, s2, w},
    s1 = {{I, tc},  {0, -I}};
    s2 = {{1,  0},  {t2c, 1}};
    w  = MatrixPower[s1, p] . MatrixPower[s2, q];
    Tr[w]]

(* Scan range matches strip: Re[t2] in [-1,1], Im[t2] in [0, Re[t]] *)
rayReMin = -1.0;  rayReMax = 1.0;
rayImMin =  0.0;  rayImMax = Re[tval];

pleatingPoint[p_Integer, q_Integer, tc_Complex, im2_Real] :=
  Module[{sol, re2, tries, result = Missing[]},
    tries = Range[rayReMin, rayReMax, (rayReMax - rayReMin)/8.];
    Do[
      sol = Quiet[re2 /. FindRoot[
        Abs[wordTrace[p, q, tc, re2 + im2*I]]^2 == 4.,
        {re2, start},
        AccuracyGoal -> 5,
        MaxIterations -> 80]];
      If[NumericQ[sol] && rayReMin <= sol <= rayReMax,
        result = sol; Break[]],
      {start, tries}];
    result]

nRayPts = 120;
imVals  = Subdivide[rayImMin, rayImMax, nRayPts];

Print[\"Computing pleating rays ...\"];
rayData = Association[];
Do[
  Module[{p, q, pts},
    p = Numerator[frac];
    q = Denominator[frac];
    pts = Table[
      Module[{re = pleatingPoint[p, q, tval, iv]},
        If[MissingQ[re], Nothing, {re, iv}]],
      {iv, imVals}];
    If[Length[pts] > 3, rayData[frac] = pts]],
  {frac, allFarey}];
Print[\"Rays with data: \", Length[rayData]]

(* --- 6. Strip overlay ------------------------------------------- *)
(* Convert t2 coords to pixel coords in strip image *)
toStripPixel[{re_, im_}] := {
  (re - rayReMin) / (rayReMax - rayReMin) * xres,
  yres - (im - rayImMin) / (rayImMax - rayImMin) * yres};

rayColors = ColorData[\"DarkRainbow\"];
nFracs    = Length[allFarey];

stripRayLines = Table[
  Module[{frac = allFarey[[k]], col},
    col = rayColors[k/nFracs];
    If[KeyExistsQ[rayData, frac],
      {col, Thickness[0.002],
       Line[toStripPixel /@ rayData[frac]]},
      Nothing]],
  {k, 1, nFracs}];

stripRayLabels = Table[
  Module[{frac = allFarey[[k]], mid, px},
    If[KeyExistsQ[rayData, frac] && Length[rayData[frac]] > 10,
      mid = rayData[frac][[Round[Length[rayData[frac]]/2]]];
      px  = toStripPixel[mid];
      Text[Style[ToString[frac], 8, Bold, rayColors[k/nFracs]], px],
      Nothing]],
  {k, 1, nFracs}];

stripFinal = Show[
  stripPlot,
  Graphics[{stripRayLines, stripRayLabels}],
  ImageSize -> {2000, 2000},
  PlotLabel -> Style[
    \"Kleinian Limit Set + Farey Pleating Rays (strip)\\nt = \" <>
    ToString[N[tval,4]] <> \"   Farey depth = \" <> ToString[fareyDepth],
    13, Bold]];

stripFinal

(* --- 7. Poincare disk map  f[z] = (1+z)/(1-z) ------------------ *)
Print[\"Mapping to Poincare disk via f[z]=(1+z)/(1-z) ...\"];

(* First normalise strip coords to [-1,1] x [-1,1] then map *)
(* Strip: Re in [-1,1], Im in [0, Re[t]]
   Normalise Im to [-1,1]: w = re + I*(2*im/Re[t] - 1)          *)
normaliseStrip[{re_, im_}] :=
  re + I*(2.*im/Re[tval] - 1.);

diskMap[z_] := (1. + z)/(1. - z);

toDisk[pt_] :=
  Module[{z, w},
    z = normaliseStrip[pt];
    w = diskMap[z];
    If[Abs[w] <= 1.02, {Re[w], Im[w]}, Nothing]]

diskRayLines = Table[
  Module[{frac = allFarey[[k]], mapped, col},
    col = rayColors[k/nFracs];
    If[KeyExistsQ[rayData, frac],
      mapped = Select[toDisk /@ rayData[frac], (# =!= Nothing)&];
      If[Length[mapped] > 2,
        {col, Thickness[0.006], Line[mapped]},
        Nothing],
      Nothing]],
  {k, 1, nFracs}];

diskRayLabels = Table[
  Module[{frac = allFarey[[k]], mapped, mid},
    If[KeyExistsQ[rayData, frac] && Length[rayData[frac]] > 10,
      mapped = Select[toDisk /@ rayData[frac], (# =!= Nothing)&];
      If[Length[mapped] > 5,
        mid = mapped[[Round[Length[mapped]/2]]];
        Text[Style[ToString[frac], 9, Bold, rayColors[k/nFracs]], mid],
        Nothing],
      Nothing]],
  {k, 1, nFracs}];

(* Map the escape grid itself into the disk via pixel -> t2 -> disk *)
Print[\"Mapping escape grid to disk (this may take a moment) ...\"];
diskRes = 600;
diskImg = Table[
  Module[{w, z, re, im, ix, iy, val},
    w = px + I*py;
    If[Abs[w] > 1., 0,
      (* inverse disk map: z = (w-1)/(w+1), then denormalise *)
      z  = (w - 1.)/(w + 1.);
      re = Re[z];
      im = (Im[z] + 1.)/2. * Re[tval];
      (* nearest pixel in strip grid *)
      ix = Round[(re - rayReMin)/(rayReMax - rayReMin)*(xres-1)] + 1;
      iy = Round[(im - rayImMin)/(rayImMax - rayImMin)*(yres-1)] + 1;
      If[1 <= ix <= xres && 1 <= iy <= yres,
        imgStrip[[iy, ix]], 0]]],
  {py, -1., 1., 2./(diskRes-1)},
  {px, -1., 1., 2./(diskRes-1)}];

diskEscape = MatrixPlot[diskImg,
  DataReversed -> {False, True},
  ImageSize -> 800,
  ColorFunctionScaling -> False,
  ColorFunction -> (Which[
    # <= 0,  White,
    # == 1,  dodger,
    # == 2,  Red,
    True,    Green] &),
  Frame -> False];

(* Unit circle and disk boundary *)
unitCircle = {Thickness[0.005], GrayLevel[0.4], Circle[{0,0}, 1]};

diskFinal = Show[
  diskEscape,
  Graphics[{unitCircle, diskRayLines, diskRayLabels}],
  PlotRange -> {{-1.05, 1.05}, {-1.05, 1.05}},
  ImageSize -> {2000, 2000},
  PlotLabel -> Style[
    \"Kleinian Limit Set + Farey Pleating Rays (Poincare disk)\\n\" <>
    \"f[z]=(1+z)/(1-z)   t = \" <> ToString[N[tval,4]] <>
    \"   Farey depth = \" <> ToString[fareyDepth],
    13, Bold]];

diskFinal

(* --- 8. Side-by-side panel -------------------------------------- *)
panel = GraphicsGrid[
  {{stripFinal, diskFinal}},
  ImageSize -> 4000];

(* --- 9. Export -------------------------------------------------- *)
Export[\"Kleinian_rays_strip_t1p92_depth10.jpg\",
  Rasterize[stripFinal, \"Image\", ImageSize -> 2000]];
Print[\"Saved: Kleinian_rays_strip_t1p92_depth5.jpg\"]

Export[\"Kleinian_rays_disk_t1p92_depth10.jpg\",
  Rasterize[diskFinal, \"Image\", ImageSize -> 2000]];
Print[\"Saved: Kleinian_rays_disk_t1p92_depth5.jpg\"]

Export[\"Kleinian_rays_panel_t1p92_depth10.jpg\",
  Rasterize[panel, \"Image\", ImageSize -> 4000]];
Print[\"Saved: Kleinian_rays_panel_t1p92_depth5.jpg\"]

Print[\"All done.\"]
\
\>", "Input",
