Cell[BoxData[
 RowBox[{"MatrixPlot", "[", 
  RowBox[{"img", ",", " ", 
   RowBox[{"DataReversed", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"False", ",", "True"}], "}"}]}], ",", 
   RowBox[{"ImageSize", "\[Rule]", "2000"}], ",", 
   RowBox[{"AspectRatio", "\[Rule]", "1"}], ",", 
   RowBox[{"ColorFunctionScaling", "\[Rule]", "False"}], ",", 
   RowBox[{"ColorFunction", "\[Rule]", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Which", "[", 
       RowBox[{
        RowBox[{"#", "<=", "0"}], ",", "White", ",", 
        RowBox[{"#", "\[Equal]", "1"}], ",", "dodger", ",", 
        RowBox[{"#", "\[Equal]", "2."}], ",", "Red", ",", 
        RowBox[{"#", "<", "0"}], ",", 
        RowBox[{
         RowBox[{"ColorData", "[", "\"\<CMYKColors\>\"", "]"}], "[", 
