Cell[CellGroupData[{

Cell["Fast version", "Section",ExpressionUUID->"8b08c07d-82d8-4ae2-a36d-a1609530ce0e"],

Cell["\<\
The uncompiled version is already quite fast but, the compiled version is \
still faster. On my laptop the 800x800 image of the example below is \
generated in less than 4 seconds.\
\>", "Text",ExpressionUUID->"0cd17992-2b25-4768-9ac6-062666cce9a3"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"$HistoryLength", "=", "2"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"kleinC", "=", 
   RowBox[{"Compile", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"{", 
       RowBox[{"z", ",", "_Complex"}], "}"}], "}"}], ",", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"t", "=", 
          RowBox[{"1.7183922185535652`", "+", 
           RowBox[{"1.0232928140149116`", " ", "\[ImaginaryI]"}]}]}], ",", 
         " ", "u", ",", "v", ",", "xi", ",", "yi", ",", 
         RowBox[{"zi", "=", 
          RowBox[{"(", 
           RowBox[{"1.", "+", "I"}], ")"}]}], ",", 
         RowBox[{"k", "=", "1"}], ",", 
         RowBox[{"low", "=", 
          RowBox[{"1", "+", "I"}]}], ",", 
         RowBox[{"high", "=", 
          RowBox[{"1", "+", "I"}]}]}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"xi", "=", 
         RowBox[{"Re", "[", "z", "]"}]}], ";", " ", 
        RowBox[{"yi", "=", 
         RowBox[{"Im", "[", "z", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"u", "=", 
         RowBox[{"Re", "[", "t", "]"}]}], ";", " ", 
        RowBox[{"v", "=", 
         RowBox[{"Im", "[", "t", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"yi", "<", "0"}], "||", 
           RowBox[{"yi", ">", "u"}]}], ",", 
          RowBox[{"Return", "[", "0", "]"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Do", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{"xi", "=", 
            RowBox[{
             RowBox[{"Mod", "[", 
              RowBox[{
               RowBox[{"xi", "+", "1.", "+", 
                RowBox[{"v", "  ", 
                 RowBox[{"yi", "/", "u"}]}]}], ",", "2"}], "]"}], "-", "1", 
             "-", 
             RowBox[{"v", " ", 
              RowBox[{"yi", "/", "u"}]}]}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"zi", "=", 
            RowBox[{"xi", "+", 
             RowBox[{"I", " ", "yi"}]}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"(*", 
            RowBox[{"check", " ", "separation", " ", "line"}], "*)"}], 
           "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"yi", "<", 
              RowBox[{
               RowBox[{"u", "/", "2."}], "+", 
               RowBox[{
                RowBox[{"Sign", "[", 
                 RowBox[{"xi", "+", 
                  RowBox[{"v", "/", "2"}]}], "]"}], "0.2", "*", "u", 
                RowBox[{"(", 
                 RowBox[{"1", "-", 
                  RowBox[{"Exp", "[", 
                   RowBox[{
                    RowBox[{"-", "5."}], 
                    RowBox[{"Abs", "[", 
                    RowBox[{"xi", "+", 
                    RowBox[{"v", "/", "2."}]}], "]"}]}], "]"}]}], ")"}]}]}]}],
              ",", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"Abs", "[", 
                  RowBox[{"zi", "-", "low"}], "]"}], "<", 
                 RowBox[{"10", "^", 
                  RowBox[{"-", "4"}]}]}], " ", ",", 
                RowBox[{
                 RowBox[{"k", "=", 
                  RowBox[{"-", "n"}]}], ";", 
                 RowBox[{"Break", "[", "]"}]}], ",", 
                RowBox[{"low", "=", "zi"}]}], "]"}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"k", "=", "1"}], ";", "\[IndentingNewLine]", 
              RowBox[{"zi", "=", 
               RowBox[{"(*", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"t", "*", "zi"}], "-", "I"}], ")"}], "/", 
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"-", "I"}], " ", "*", "zi"}], ")"}]}], "*)"}], 
               RowBox[{
                RowBox[{"I", "*", "t"}], "+", 
                RowBox[{"1.", "/", "zi"}]}]}]}], ",", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"Abs", "[", 
                  RowBox[{"zi", "-", "high"}], "]"}], "<", 
                 RowBox[{"10", "^", 
                  RowBox[{"-", "4"}]}]}], " ", ",", 
                RowBox[{
                 RowBox[{"k", "=", 
                  RowBox[{"-", "n"}]}], ";", 
                 RowBox[{"Break", "[", "]"}]}], ",", 
                RowBox[{"high", "=", "zi"}]}], "]"}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"zi", "=", 
               RowBox[{"I", "/", 
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"I", " ", "*", "zi"}], "+", "t"}], ")"}]}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"k", "=", "2"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
           RowBox[{"xi", "=", 
            RowBox[{"Re", "[", "zi", "]"}]}], ";", " ", 
           RowBox[{"yi", "=", 
            RowBox[{"Im", "[", "zi", "]"}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"yi", "<", "0"}], "||", 
              RowBox[{"yi", ">", "u"}]}], " ", ",", " ", 
             RowBox[{"Break", "[", "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
           RowBox[{"k", "=", "3"}]}], ",", "\[IndentingNewLine]", 
          RowBox[{"{", 
           RowBox[{"n", ",", "1", ",", "30"}], "}"}]}], "\[IndentingNewLine]",
          "]"}], ";", "\[IndentingNewLine]", "k"}]}], "]"}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}]}], "Input",
