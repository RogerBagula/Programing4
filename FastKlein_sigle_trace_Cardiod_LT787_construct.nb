Cell["\<\
 In this example the part belonging to the generators \
\[OpenCurlyDoubleQuote]a\[CloseCurlyDoubleQuote] and \[OpenCurlyDoubleQuote]A\
\[CloseCurlyDoubleQuote] are colored blue and red. The coordinates where the \
maximum iteration depth (escape time) is reached is colored green.\
\>", "Text",ExpressionUUID->"5cb59137-84be-4049-a22d-5880a919bbe8"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"res", "=", "2000"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"dodger", "=", 
   RowBox[{"ColorData", "[", 
    RowBox[{"\"\<Legacy\>\"", ",", "\"\<DodgerBlue\>\""}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"xres", "=", "res"}], ";", " ", 
  RowBox[{"yres", "=", "res"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"dx", "=", 
   RowBox[{"2.", "/", 
    RowBox[{"(", 
     RowBox[{"xres", "-", "1"}], ")"}]}]}], ";", " ", 
  RowBox[{"dy", "=", 
   RowBox[{"2.", "/", 
    RowBox[{"(", 
     RowBox[{"yres", "-", "1"}], ")"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"t0", "=", 
   RowBox[{"AbsoluteTime", "[", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"img", "=", 
   RowBox[{"ParallelTable", "[", 
    RowBox[{
     RowBox[{"kleinC", "[", 
      RowBox[{"(", 
       RowBox[{"x", "+", 
        RowBox[{"I", " ", "y"}]}], ")"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"y", ",", "0", ",", "2", ",", "dy"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", "1"}], ",", "1", ",", "dx"}], "}"}]}], "]"}]}], 
  ";"}]}], "Input",
