Cell["\<\
By using a pre-transform  additional shapes can be generated. Below an \
inversion at a circle centered at p = (0 + I) with radius = 1 is  executed.\
\>", "Text",ExpressionUUID->"ff6721f1-95a5-4260-9d5b-9f96723e4dc9"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"res", "=", "2000"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"dodger", ",", "navy"}], "}"}], "=", 
   RowBox[{
    RowBox[{
     RowBox[{"ColorData", "[", 
      RowBox[{"\"\<Legacy\>\"", ",", "#"}], "]"}], "&"}], "/@", 
    RowBox[{"{", 
     RowBox[{"\"\<DodgerBlue\>\"", ",", "\"\<Navy\>\""}], "}"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"xres", "=", "res"}], ";", " ", 
  RowBox[{"yres", "=", "res"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"dx", "=", 
   RowBox[{"1", "/", 
    RowBox[{"(", 
     RowBox[{"xres", "-", "1"}], ")"}]}]}], ";", " ", 
  RowBox[{"dy", "=", 
   RowBox[{"1", "/", 
    RowBox[{"(", 
     RowBox[{"yres", "-", "1"}], ")"}]}]}], ";"}], "\[IndentingNewLine]", 
