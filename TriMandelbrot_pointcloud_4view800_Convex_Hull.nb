Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "Run", " ", "this", " ", "in", " ", "a", " ", "fresh", " ", "cell"}], "-", 
    RowBox[{"skips", " ", "ListSurfacePlot3D", " ", "entirely"}]}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"gP", "=", 
     RowBox[{"ListPointPlot3D", "[", 
      RowBox[{"surfacePts", ",", 
       RowBox[{"PlotStyle", "->", 
        RowBox[{"Directive", "[", 
         RowBox[{"PointSize", "[", "0.001", "]"}], "]"}]}], ",", 
       RowBox[{"ColorFunction", "->", "\"\<AuroraColors\>\""}], ",", 
       RowBox[{"BoxRatios", "->", 
        RowBox[{"{", 
         RowBox[{"1", ",", "1", ",", "1"}], "}"}]}], ",", 
       RowBox[{"PlotRange", "->", "All"}], ",", 
       RowBox[{"AxesLabel", "->", 
        RowBox[{"{", 
         RowBox[{"\"\<x\>\"", ",", "\"\<y\>\"", ",", "\"\<z\>\""}], "}"}]}], 
       ",", 
       RowBox[{"ImageSize", "->", "2000"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"g1", "=", "gP"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"g2", "=", 
     RowBox[{"Show", "[", 
      RowBox[{"gP", ",", 
       RowBox[{"ViewPoint", "->", 
        RowBox[{"{", 
         RowBox[{"2", ",", "2", ",", "2"}], "}"}]}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"g3", "=", 
