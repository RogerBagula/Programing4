   RowBox[{
    RowBox[{"g4", "=", 
     RowBox[{"Show", "[", 
      RowBox[{"gP", ",", 
       RowBox[{"ViewPoint", "->", "Right"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"grid", "=", 
     RowBox[{"GraphicsGrid", "[", 
