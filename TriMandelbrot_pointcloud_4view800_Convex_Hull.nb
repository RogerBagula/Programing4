       "\[IndentingNewLine]", 
       RowBox[{"verts", "=", 
        RowBox[{"MeshCoordinates", "[", "ch", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"faces", "=", 
        RowBox[{
         RowBox[{"MeshCells", "[", 
          RowBox[{"ch", ",", "2"}], "]"}], "[", 
