       "\[IndentingNewLine]", 
       RowBox[{"vol", "=", 
        RowBox[{"N", "[", 
         RowBox[{"RegionMeasure", "[", "ch", "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<Convex hull: \>\"", ",", 
         RowBox[{"Length", "[", "verts", "]"}], ",", "\"\< verts, \>\"", ",", 
         
         RowBox[{"Length", "[", "faces", "]"}], ",", 
         "\"\< faces, volume = \>\"", ",", "vol"}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Export", "[", 
        RowBox[{
        "\"\<TriMandelbrot_pointcloud_4view800_convex_hull.obj\>\"", ",", 
