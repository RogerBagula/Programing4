  RowBox[{"(*", " ", 
   RowBox[{"===", 
    RowBox[{"==", 
     RowBox[{"Convex", " ", "Hull", " ", "Export"}]}], "===", "=="}], "*)"}], 
  
  RowBox[{
   RowBox[{
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"ch", ",", "verts", ",", "faces", ",", "vol"}], "}"}], ",", 
      RowBox[{
       RowBox[{"Print", "[", 
        RowBox[{"\"\<Building convex hull from \>\"", ",", 
         RowBox[{"Length", "[", "surfacePts", "]"}], ",", 
         "\"\< surface points...\>\""}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"ch", "=", 
