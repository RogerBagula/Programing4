       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"g1", ",", "g2"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"g3", ",", "g4"}], "}"}]}], "}"}], ",", 
       RowBox[{"ImageSize", "->", "4000"}]}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Export", "[", 
