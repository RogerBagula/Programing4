Notebook[{
Cell["\<\
(* ============================================================
   TriMandelbrot Surface Renderer  -  n = 2 power
   Tested for Mathematica 13.2
   Grid: 500^3 preview  (raise nx/ny/nz to 300+ for final)
   ============================================================ *)\
\>", "Input",
 CellChangeTimes->{{3.9884910448151817`*^9, 3.988491045931093*^9}, {
   3.988491309547956*^9, 3.988491372053913*^9}, 3.988492004850649*^9, {
   3.9884940890391607`*^9, 3.988494324022293*^9}, {3.9884943646845703`*^9, 
   3.9884943897483397`*^9}, 3.98849463126661*^9, 3.988494688805971*^9, 
   3.988495596848441*^9, {3.988496065808514*^9, 3.988496073911569*^9}, 
   3.988496304279312*^9, 3.9884971086752253`*^9},
 CellLabel->"In[1]:=",ExpressionUUID->"672f1d9b-f956-4b8b-a5a1-062fee2c80b2"],

Cell[CellGroupData[{

Cell["\<\

(* --- 1. Compiled escape-time function --------------------------- *)
escapeTime3D =
  Compile[{{x0, _Real}, {y0, _Real}, {z0, _Real}, {maxIter, _Integer}},
    Module[{xr = 0., yr = 0., zr = 0.,
            xr2, yr2, zr2,
            r, theta, phi,
            i = 0},
      While[i < maxIter,
        r = Sqrt[xr*xr + yr*yr + zr*zr];
        If[r > 0.,
          theta = ArcTan[xr, yr];
          phi   = ArcCos[Clip[zr/r, {-1., 1.}]];
          xr2 = r^2 * Cos[2*phi]*(1+Cos[2*theta])+ x0;
          yr2 = r^2 * Cos[2*phi+2*Pi/3]*(1+Cos[2*theta+2*Pi/3])+ y0;
          zr2 = r^2 * Cos[2*phi-2*Pi/3]*(1+Cos[2*theta-2*Pi/3])+ z0,
          xr2 = x0;
          yr2 = y0;
          zr2 = z0];
        xr = xr2; yr = yr2; zr = zr2;
        If[xr*xr + yr*yr + zr*zr > 4.0, Return[i]];
        i++];
      maxIter],
    CompilationTarget -> \"C\",
    RuntimeOptions -> \"Speed\"]

(* --- 2. Quick sanity check -------------------------------------- *)
Print[\"Sanity check (expect 40, small, 40):\"];
Print[escapeTime3D[0., 0., 0., 40]];
Print[escapeTime3D[2., 0., 0., 40]];
Print[escapeTime3D[0.3, 0.1, 0.1, 40]];

(* --- 3. Grid parameters ----------------------------------------- *)
maxIter = 40;
nx = ny = nz = 800;
xmin = ymin = zmin = -1.5;
xmax = ymax = zmax =  1.5;
dx = (xmax - xmin) / (nx - 1);
dy = (ymax - ymin) / (ny - 1);
dz = (zmax - zmin) / (nz - 1);

(* --- 4. Classify voxels ----------------------------------------- *)
Print[\"Classifying voxels ...\"];
AbsoluteTiming[
  rawCounts = Table[
    escapeTime3D[
      xmin + (i-1)*dx,
      ymin + (j-1)*dy,
      zmin + (k-1)*dz,
      maxIter],
    {i, 1, nx}, {j, 1, ny}, {k, 1, nz}];
  inside = Map[(# == maxIter)&, rawCounts, {3}];
]

(* --- 5. Extract surface voxels ---------------------------------- *)
Print[\"Extracting surface points ...\"];
AbsoluteTiming[
  collected = Reap[
    Do[
      If[inside[[i, j, k]],
        If[MemberQ[
             {inside[[i+1,j,k]], inside[[i-1,j,k]],
              inside[[i,j+1,k]], inside[[i,j-1,k]],
              inside[[i,j,k+1]], inside[[i,j,k-1]]},
             False],
          Sow[{xmin+(i-1)*dx,
               ymin+(j-1)*dy,
               zmin+(k-1)*dz}]]],
      {i, 2, nx-1}, {j, 2, ny-1}, {k, 2, nz-1}]];
  surfacePts = If[Length[collected[[2]]] > 0, collected[[2,1]], {}];
]
Print[\"Surface points: \", Length[surfacePts]]\
\>", "Input",
 CellChangeTimes->{{3.9884910448151817`*^9, 3.988491045931093*^9}, {
