           RowBox[{"k", ",", "length"}], "}"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"M", "=", 
         RowBox[{"Fold", "[", 
          RowBox[{"Dot", ",", 
           RowBox[{"IdentityMatrix", "[", "3", "]"}], ",", 
           RowBox[{
            RowBox[{
             RowBox[{"generators", "[", 
              RowBox[{"[", "#", "]"}], "]"}], "&"}], "/@", "idxList"}]}], 
          "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"normalizeSL3", "[", "M", "]"}]}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"--", 
      RowBox[{"--", 
       RowBox[{"--", 
        RowBox[{"--", 
         RowBox[{"--", 
          RowBox[{"--", 
           RowBox[{"--", 
            RowBox[{"--", "Map"}]}]}]}]}]}]}]}], " ", "matrix", " ", "action",
      " ", "to", " ", "unit", " ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"sphere", "--"}], "--"}], "--"}], "--"}], "--"}], "--"}], 
       "--"}], "--"}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"mapToSphere", "[", 
      RowBox[{"M_", ",", "p_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"v", ",", "vproj"}], "}"}], ",", 
       RowBox[{
        RowBox[{"v", "=", 
         RowBox[{"M", ".", "p"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Max", "[", 
            RowBox[{"Abs", "[", "v", "]"}], "]"}], "==", "0"}], ",", 
          RowBox[{"Return", "[", 
           RowBox[{"{", 
            RowBox[{"0.", ",", "0.", ",", "0."}], "}"}], "]"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"vproj", "=", 
         RowBox[{"v", "/", 
          RowBox[{"Max", "[", 
           RowBox[{"Abs", "[", "v", "]"}], "]"}]}]}], ";", 
        RowBox[{"(*", 
         RowBox[{"projective", " ", "normalization"}], "*)"}], 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Norm", "[", "vproj", "]"}], "==", "0"}], ",", 
          RowBox[{"{", 
           RowBox[{"0.", ",", "0.", ",", "0."}], "}"}], ",", 
          RowBox[{"vproj", "/", 
           RowBox[{"Norm", "[", "vproj", "]"}]}]}], "]"}]}]}], "  ", 
      RowBox[{"(*", 
       RowBox[{"map", " ", "to", " ", "unit", " ", "sphere"}], "*)"}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"--", 
      RowBox[{"--", 
       RowBox[{"--", 
        RowBox[{"--", 
         RowBox[{"--", 
          RowBox[{"--", 
           RowBox[{"--", 
            RowBox[{"--", "Generate"}]}]}]}]}]}]}]}], " ", "points", " ", 
     "in", " ", "batches", " ", "using", " ", 
     RowBox[{"Reap", "/", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"Sow", "--"}], "--"}], "--"}], "--"}], "--"}], "--"}], 
        "--"}], "--"}]}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"SeedRandom", "[", "1234", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"batchSize", "=", "5000"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"batches", "=", 
     RowBox[{"Ceiling", "[", 
      RowBox[{"numOrbits", "/", "batchSize"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"points", "=", 
     RowBox[{
      RowBox[{"Reap", "[", 
       RowBox[{
        RowBox[{"Do", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Do", "[", 
            RowBox[{
             RowBox[{"Module", "[", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{"M", ",", "p"}], "}"}], ",", 
               RowBox[{
                RowBox[{"M", "=", 
                 RowBox[{
                 "randomReducedWordMatrix", "[", "wordLength", "]"}]}], ";", 
                "\[IndentingNewLine]", 
                RowBox[{"p", "=", 
                 RowBox[{"mapToSphere", "[", 
                  RowBox[{"M", ",", "startPoint"}], "]"}]}], ";", 
                "\[IndentingNewLine]", 
                RowBox[{"If", "[", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"Norm", "[", "p", "]"}], ">", "0"}], ",", 
                  RowBox[{"Sow", "[", "p", "]"}]}], "]"}], ";"}]}], "]"}], 
             ",", 
             RowBox[{"{", 
              RowBox[{"j", ",", 
               RowBox[{"Min", "[", 
                RowBox[{"batchSize", ",", 
                 RowBox[{"numOrbits", "-", 
                  RowBox[{
                   RowBox[{"(", 
                    RowBox[{"i", "-", "1"}], ")"}], "*", "batchSize"}]}]}], 
                "]"}]}], "}"}]}], "]"}], ";", "\[IndentingNewLine]", 
           RowBox[{"Print", "[", 
            RowBox[{
            "\"\<Completed batch \>\"", ",", "i", ",", "\"\< / \>\"", ",", 
             "batches"}], "]"}], ";"}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "batches"}], "}"}]}], "]"}], ";"}], "]"}], "[", 
      RowBox[{"[", 
