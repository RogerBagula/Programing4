              ",", "p", ",", "firstIdx"}], "}"}], ",", 
            RowBox[{
             RowBox[{"Do", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"idx", "=", 
                 RowBox[{"RandomInteger", "[", 
